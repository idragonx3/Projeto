<%- include('partials/header') %>
<body>
    <%- include('partials/navbar') %>
    <div class="container">
        <div class="card" id="formulario-pergunta">
            <div class="card-header">
                <h3>Realizar pergunta</h3>
            </div>
            <div class="card-body">
                <form action="/salvarpergunta" method="POST">
                 <hr>
                <label for="titulo">Título</label>
                <input type="text" placeholder="Título " class="form-control" name="titulo">
                <br>
                <label for="descricao">Descrição</label>
                <textarea name="descricao" placeholder="Descrição da sua pergunta" class="form-control"></textarea></textarea>
                <br>
                <button class="btn btn-dark" type="submit">Perguntar</button>
        </form>
            </div>
        </div>
    </div>
</body>
<%- include('partials/footer') %>